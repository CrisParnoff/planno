# ================= Backend — variáveis de ambiente =================
# Copie para .env e preencha. NUNCA versione o .env real.

ENV=development

# --- Supabase (Project Settings > API) ---
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# JWT Secret legado (Project Settings > API > JWT Secret). Se seu projeto
# usa chaves assimétricas novas, deixe vazio que o backend usa o JWKS.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

# --- Banco (Project Settings > Database > Connection string > URI) ---
# Use o formato do driver psycopg2:
DATABASE_URL=postgresql+psycopg2://postgres:SUA_SENHA@db.SEU-PROJETO.supabase.co:5432/postgres

# --- Google OAuth (Google Cloud Console > Credentials) ---
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# --- Criptografia dos refresh tokens do Google ---
# Gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Segredo do cron (invente um valor forte e aleatório) ---
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
CRON_SECRET=

# --- CORS: origens do frontend (dev) ---
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

APP_TIMEZONE=America/Sao_Paulo
